[Unit]
Description=pyBulletin BBS service (core + web)
After=network-online.target
Wants=network-online.target
Conflicts=pybulletin-web.service

[Service]
Type=simple
User=pybulletin
Group=pybulletin
WorkingDirectory=/home/pybulletin/pyBulletin
Environment=PYTHONPATH=src
ExecStart=/usr/local/bin/pybulletin-python -m pybulletin.cli --config config/pybulletin.toml serve
Restart=on-failure
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=45

[Install]
WantedBy=multi-user.target
